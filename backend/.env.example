PORT=5000

# === Database Configuration ===
# The application automatically detects if DATABASE_URL is set.
# If it is, the individual DB_* variables are ignored.

# Method 1: Railway / Cloud Provider URL
DATABASE_URL=mysql://username:password@host:port/database

# Method 2: Individual Variables (Fallback)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1234
DB_NAME=transitops

# Optional settings
DB_SSL=false

# Authentication
JWT_SECRET=your_secret
NODE_ENV=development
